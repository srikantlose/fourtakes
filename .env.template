# Fireworks API Configuration
# Model names are config values ONLY — never hardcoded in pipeline code.
# Track 2 has no model restriction, so pick the vision model that scores best.
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_CAPTION_MODEL=accounts/fireworks/models/qwen2p5-vl-32b-instruct
FIREWORKS_TRANSCRIPTION_MODEL=whisper-v3

# Mock mode: true = no real API calls, canned responses (for development)
MOCK_MODE=false

# Frame Extraction Settings
FRAME_INTERVAL_SECONDS=1.5
# Cap on frames actually sent to the vision model (evenly sampled from
# all extracted frames). Protects against per-request image limits and
# runaway token costs on longer clips.
MAX_FRAMES=16
# Frames wider than this are downscaled before encoding (UHD source clips
# would otherwise produce huge payloads). 0 disables scaling.
FRAME_SCALE_WIDTH=512

# Audio Transcription (uses the same Fireworks API key).
# Off by default in the Docker image to protect the judging time budget.
ENABLE_AUDIO_TRANSCRIPTION=true

# Submission (task) mode — paths the judging harness mounts
TASKS_PATH=/input/tasks.json
RESULTS_PATH=/output/results.json
# Videos processed in parallel during a batch run
MAX_CONCURRENT_TASKS=3
# Timeouts in seconds
DOWNLOAD_TIMEOUT=120
API_TIMEOUT=60

# Prompts file (base caption + style prompts + generic fallback template)
PROMPTS_PATH=config/prompts.json

# Logging
LOG_LEVEL=INFO
LOG_FILE=fourtakes.log

# Output (local dev mode)
OUTPUT_DIR=output
TEMP_DIR=.temp
